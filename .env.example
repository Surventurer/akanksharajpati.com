# ===========================================
# LOCAL DEVELOPMENT (Docker MongoDB)
# ===========================================
# Use this for local development with docker-compose
DATABASE_URI=mongodb://admin:password@127.0.0.1:27017/akanksharajpati?authSource=admin

# ===========================================
# PRODUCTION (MongoDB Atlas) - Set in Vercel Dashboard
# ===========================================
# DATABASE_URI=mongodb+srv://user:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority

# ===========================================
# Authentication
# ===========================================
PAYLOAD_SECRET=your-super-secret-key-here

# Admin credentials for seeding
CMS_SEED_ADMIN_EMAIL=admin@example.com
CMS_SEED_ADMIN_PASSWORD=your-password-here

# ===========================================
# Optional: Email & Storage (for Vercel)
# ===========================================
# RESEND_API_KEY=your-resend-api-key
# BLOB_READ_WRITE_TOKEN=your-vercel-blob-token