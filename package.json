        "typescript": "5.7.3",
        "vite-tsconfig-paths": "5.1.4",
        "vitest": "3.2.3"
    },
    "engines": {
        "node": "^18.20.2 || >=20.9.0",
        "pnpm": "9.15.4"
    },
    "packageManager": "pnpm@9.15.4",
    "pnpm": {
        "onlyBuiltDependencies": [
            "sharp",
            "esbuild",
            "unrs-resolver"
        ]
    }
}