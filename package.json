{
    "name": "cms",
    "version": "1.0.0",
    "description": "A blank template to get started with Payload 3.0",
    "license": "MIT",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build",
        "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev --webpack",
        "devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev",
        "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
        "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
        "lint": "eslint . --max-warnings=200",
        "format": "prettier . --write",
        "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
        "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
        "seed": "tsx -r dotenv/config src/scripts/seed/script.ts",
        "nuke": "psql -d payload_next_blog -c \"DROP SCHEMA public CASCADE; CREATE SCHEMA public;\" && pnpm payload migrate:fresh && pnpm seed"
    },
    "dependencies": {
        "@payloadcms/db-mongodb": "3.74.0",
        "@payloadcms/db-postgres": "3.74.0",
        "@payloadcms/email-resend": "^3.74.0",
        "@payloadcms/next": "3.74.0",
        "@payloadcms/richtext-lexical": "3.74.0",
        "@payloadcms/storage-vercel-blob": "^3.74.0",
        "@payloadcms/ui": "3.74.0",
        "@plaiceholder/next": "^3.0.0",
        "@radix-ui/react-accordion": "^1.2.12",
        "@radix-ui/react-alert-dialog": "^1.1.15",
        "@radix-ui/react-aspect-ratio": "^1.1.8",
        "@radix-ui/react-avatar": "^1.1.11",
        "@radix-ui/react-checkbox": "^1.3.3",
        "@radix-ui/react-collapsible": "^1.1.12",
        "@radix-ui/react-context-menu": "^2.2.16",
        "@radix-ui/react-dialog": "^1.1.15",
        "@radix-ui/react-dropdown-menu": "^2.1.16",
        "@radix-ui/react-hover-card": "^1.1.15",
        "@radix-ui/react-label": "^2.1.8",
        "@radix-ui/react-menubar": "^1.1.16",
        "@radix-ui/react-navigation-menu": "^1.2.14",
        "@radix-ui/react-popover": "^1.1.15",
        "@radix-ui/react-progress": "^1.1.8",
        "@radix-ui/react-radio-group": "^1.3.8",
        "@radix-ui/react-scroll-area": "^1.2.10",
        "@radix-ui/react-select": "^2.2.6",
        "@radix-ui/react-separator": "^1.1.8",
        "@radix-ui/react-slider": "^1.3.6",
        "@radix-ui/react-slot": "^1.2.4",
        "@radix-ui/react-switch": "^1.2.6",
        "@radix-ui/react-tabs": "^1.1.13",
        "@radix-ui/react-toast": "^1.2.15",
        "@radix-ui/react-toggle": "^1.1.10",
        "@radix-ui/react-toggle-group": "^1.1.11",
        "@radix-ui/react-tooltip": "^1.2.8",
        "@t3-oss/env-nextjs": "^0.13.8",
        "@tailwindcss/postcss": "^4.1.17",
        "@tailwindcss/typography": "^0.5.19",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "cmdk": "^1.1.1",
        "date-fns": "^4.1.0",
        "dotenv": "16.4.7",
        "embla-carousel-react": "^8.6.0",
        "graphql": "^16.8.1",
        "input-otp": "^1.4.2",
        "lucide-react": "^0.563.0",
        "next": "^16.1.6",
        "next-themes": "^0.4.6",
        "payload": "3.74.0",
        "plaiceholder": "^3.0.0",
        "postcss": "^8.5.6",
        "react": "19.1.0",
        "react-day-picker": "^9.13.0",
        "react-dom": "19.1.0",
        "react-hook-form": "^7.71.1",
        "react-resizable-panels": "^4.5.6",
        "recharts": "^3.7.0",
        "sharp": "0.34.2",
        "sonner": "^2.0.7",
        "tailwind-merge": "^3.4.0",
        "tailwindcss": "^4.1.17",
        "vaul": "^1.1.2",
        "zod": "^4.1.12"
    },
    "devDependencies": {
        "@faker-js/faker": "^10.1.0",
        "@playwright/test": "1.56.1",
        "@testing-library/react": "16.3.0",
        "@types/estree-jsx": "^1.0.5",
        "@types/node": "^22.19.7",
        "@types/react": "^19.1.8",
        "@types/react-dom": "^19.1.6",
        "@vitejs/plugin-react": "4.5.2",
        "cross-env": "^10.1.0",
        "eslint": "^9.16.0",
        "eslint-config-next": "^16.1.6",
        "jsdom": "26.1.0",
        "playwright": "1.56.1",
        "playwright-core": "1.56.1",
        "prettier": "^3.4.2",
        "react-router-dom": "^7.13.0",
